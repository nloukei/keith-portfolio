---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import FloatingModeSwitch from '../components/FloatingModeSwitch';

const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/letter-k.png" />
		<link rel="apple-touch-icon" href="/letter-k.png" />
	<meta name="generator" content={Astro.generator} />
	<title>Portfolio</title>
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&display=swap" rel="stylesheet" />
		<ClientRouter />
	</head>
	<body class="pb-28">
		<slot />
		<FloatingModeSwitch client:load currentPath={pathname} />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
